  <defs id="defs1"/>
  <g inkscape:label="Ebene 1" xmlns:inkscape="http://www.inkscape.org/namespaces/inkscape" inkscape:groupmode="layer" id="layer1">
    <text xml:space="preserve" style="font-size:19.7556px;line-height:1.25;font-family:Dali;-inkscape-font-specification:Dali;text-align:center;letter-spacing:0px;word-spacing:0px;text-anchor:middle;stroke-width:0.264583" x="32.753601" y="16.18647" id="text1"><tspan sodipodi:role="line" xmlns:sodipodi="http://sodipodi.sourceforge.net/DTD/sodipodi-0.dtd" id="tspan1" style="font-style:normal;font-variant:normal;font-weight:normal;font-stretch:normal;font-size:19.7556px;font-family:Caveat;-inkscape-font-specification:Caveat;stroke-width:0.264583" x="32.753597" y="16.18647">Signature</tspan></text>
