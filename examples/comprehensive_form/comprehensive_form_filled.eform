<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 210 634"><g transform="translate(0, 0)">

  <style>
    .label { font-size: 4px; sans-serif-serif; }
    .field { fill: none; stroke: black; stroke-width: 0.3; }
    .section { font-size: 5px; font-weight: bold; }
    .title { font-size: 5.5px; font-weight: bold; }
  </style>

  <!-- Header -->
  <g transform="translate(20,8) scale(0.08)">
    <rect x="40" y="40" width="240" height="240" rx="32" fill="#7fbf5f" stroke="#e67600" stroke-width="40"/>
    <rect x="80" y="80" width="160" height="40" rx="20" fill="#000"/>
    <rect x="80" y="140" width="120" height="40" rx="20" fill="#000"/>
    <rect x="80" y="200" width="120" height="40" rx="20" fill="#000"/>
  </g>

  <text x="110" y="18" text-anchor="middle" class="title">
    <tspan>eForm Comprehensive Example Form</tspan>
  </text>

  <!-- Personal Information -->
  <text x="20" y="45" class="section"><tspan>Personal Information</tspan></text>

  <text x="20" y="58" class="label" data-eform-label="f1"><tspan>First Name</tspan></text>
  <rect class="field" data-eform-field="f1" x="80" y="53" width="100" height="8"/>

  <text x="20" y="72" class="label" data-eform-label="f2"><tspan>Last Name</tspan></text>
  <rect class="field" data-eform-field="f2" x="80" y="67" width="100" height="8"/>

  <text x="20" y="86" class="label" data-eform-label="f3"><tspan>Birth Date</tspan></text>
  <rect class="field" data-eform-field="f3" x="80" y="81" width="60" height="8"/>

  <text x="20" y="100" class="label" data-eform-label="f4"><tspan>Country</tspan></text>
  <rect class="field" data-eform-field="f4" x="80" y="95" width="60" height="8"/>

  <text x="20" y="114" class="label" data-eform-label="f5"><tspan>Gender</tspan></text>
  <rect class="field" data-eform-field="f5" x="80" y="109" width="60" height="8"/>

  <!-- Contact -->
  <text x="20" y="132" class="section"><tspan>Contact</tspan></text>

  <text x="20" y="146" class="label" data-eform-label="f6"><tspan>Phone (+49...)</tspan></text>
  <rect class="field" data-eform-field="f6" x="80" y="141" width="100" height="8"/>

  <text x="20" y="160" class="label" data-eform-label="f7"><tspan>Email</tspan></text>
  <rect class="field" data-eform-field="f7" x="80" y="155" width="100" height="8"/>

  <!-- Banking -->
  <text x="20" y="178" class="section"><tspan>Banking</tspan></text>

  <text x="20" y="192" class="label" data-eform-label="f8"><tspan>IBAN</tspan></text>
  <rect class="field" data-eform-field="f8" x="80" y="187" width="100" height="8"/>

  <text x="20" y="206" class="label" data-eform-label="f9"><tspan>BIC</tspan></text>
  <rect class="field" data-eform-field="f9" x="80" y="201" width="60" height="8"/>

  <!-- Notes -->
  <text x="20" y="224" class="section"><tspan>Notes</tspan></text>

  <text x="20" y="238" class="label" data-eform-label="f10"><tspan>Short Note</tspan></text>
  <rect class="field" data-eform-field="f10" x="80" y="233" width="100" height="8"/>

  <text x="20" y="252" class="label" data-eform-label="f11"><tspan>Additional Information</tspan></text>
  <rect class="field" data-eform-field="f11" data-eform-multiline="true" x="80" y="247" width="100" height="18"/>

  <!-- Signature -->
  <text x="20" y="270" class="label" data-eform-label="f12"><tspan>Signature</tspan></text>
  <rect class="field" data-eform-field="f12" x="80" y="265" width="80" height="12"/>

<text class="field-value" data-field="f1" font-size="4" x="84" y="57" dominant-baseline="middle" text-anchor="start">John</text><text class="field-value" data-field="f2" font-size="4" x="84" y="71" dominant-baseline="middle" text-anchor="start">Doe</text><text class="field-value" data-field="f3" font-size="4" x="84" y="85" dominant-baseline="middle" text-anchor="start">01.01.1999</text><text class="field-value" data-field="f4" font-size="4" x="84" y="99" dominant-baseline="middle" text-anchor="start">Germany</text><text class="field-value" data-field="f5" font-size="4" x="84" y="113" dominant-baseline="middle" text-anchor="start">male</text><text class="field-value" data-field="f6" font-size="4" x="84" y="145" dominant-baseline="middle" text-anchor="start">3012345678</text><text class="field-value" data-field="f7" font-size="4" x="84" y="159" dominant-baseline="middle" text-anchor="start">gullivers@journeys.com</text><text class="field-value" data-field="f8" font-size="4" x="84" y="191" dominant-baseline="middle" text-anchor="start">DE121234567890123</text><text class="field-value" data-field="f9" font-size="4" x="84" y="205" dominant-baseline="middle" text-anchor="start">ABCDEFF</text><text class="field-value" data-field="f10" font-size="4" x="84" y="237" dominant-baseline="middle" text-anchor="start">laskjghapjwf</text><text class="field-value" data-field="f11" font-size="5.3999999999999995" x="84" y="256" dominant-baseline="middle" text-anchor="start">geagaerga</text></g><g class="signature" data-field="f12" transform="translate(102.81818181818181, 265.6) scale(0.4909090909090909)">
