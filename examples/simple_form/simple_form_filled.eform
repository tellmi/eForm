<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 794 1123">

<style>

text {
  font-family: sans-serif;
  font-size: 15px;
}

.title {
  font-size: 23px;
  font-weight: bold;
}

.field {
  fill: none;
  stroke: black;
  stroke-width: 1;
}

.value {
  font-family: sans-serif;
  font-size: 15px;
}

</style>

<!-- Title -->
<text class="title" x="75" y="110">
  Example eForm – Simple Registration
</text>

<!-- First name -->
<text x="75" y="170">First name</text>
<g data-eform-field="f1" data-eform-type="string" pointer-events="bounding-box">
  <rect class="field" x="260" y="155" width="380" height="38"/>
  <text class="value" x="270" y="182" dominant-baseline="middle">Richy</text>
</g>

<!-- Last name -->
<text x="75" y="250">Last name</text>
<g data-eform-field="f2" data-eform-type="string" pointer-events="bounding-box">
  <rect class="field" x="260" y="235" width="380" height="38"/>
  <text class="value" x="270" y="262" dominant-baseline="middle">Rich</text>
</g>

<!-- Birth date -->
<text x="75" y="330">Birth date</text>
<g data-eform-field="f3" data-eform-type="date" pointer-events="bounding-box">
  <rect class="field" x="260" y="315" width="230" height="38"/>
  <text class="value" x="270" y="342" dominant-baseline="middle">01.02.2003</text>
</g>

<!-- Birth country -->
<text x="75" y="410">Birth country</text>
<g data-eform-field="f4" data-eform-type="selection" pointer-events="bounding-box">
  <rect class="field" x="260" y="395" width="380" height="38"/>
  <text class="value" x="270" y="422" dominant-baseline="middle">Germany</text>
</g>

<!-- Income -->
<text x="75" y="490">Income</text>
<g data-eform-field="f5" data-eform-type="number" pointer-events="bounding-box">
  <rect class="field" x="260" y="475" width="230" height="38"/>
  <text class="value" x="270" y="502" dominant-baseline="middle">150000</text>
</g>

<!-- Expenses -->
<text x="75" y="570">Expenses</text>
<g data-eform-field="f6" data-eform-type="number" pointer-events="bounding-box">
  <rect class="field" x="260" y="555" width="230" height="38"/>
  <text class="value" x="270" y="582" dominant-baseline="middle">146000</text>
</g>

<!-- Profit -->
<text x="75" y="650">Profit</text>
<g data-eform-field="f7" data-eform-type="number" pointer-events="bounding-box">
  <rect class="field" x="260" y="635" width="230" height="38"/>
  <text class="value" x="270" y="662" dominant-baseline="middle">4000</text>
</g>
  
<!-- Signature -->
<text x="75" y="730">Signature</text>
<g data-eform-field="f8" data-eform-type="signature" pointer-events="bounding-box">
  <rect class="field" x="260" y="705" width="380" height="80" fill="none" stroke="#888" stroke-dasharray="6 4"/>
<g transform="translate(260, 709) scale(3.272727272727273)">
  <sodipodi:namedview xmlns:sodipodi="http://sodipodi.sourceforge.net/DTD/sodipodi-0.dtd" id="namedview1" pagecolor="#ffffff" bordercolor="#666666" borderopacity="1.0"/>
  <defs id="defs1"/>
  <g id="layer1">
    <text xml:space="preserve" style="font-size:19.75px;line-height:1.25;font-family:Dali;-inkscape-font-specification:Dali;text-align:center;letter-spacing:0px;word-spacing:0px;text-anchor:middle;stroke-width:0.26" x="32.75" y="16.18" id="text1"><tspan id="tspan1" style="font-style:normal;font-variant:normal;font-weight:normal;font-stretch:normal;font-size:19.75px;font-family:Caveat;-inkscape-font-specification:Caveat;stroke-width:0.26" x="32.75" y="16.18">Signature</tspan></text>
  </g>
</g></g>


<!-- eform-container

-->
</svg>